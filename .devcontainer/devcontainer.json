{
    "name": "Claude Code",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "vscode",
            "USER_UID": "1000",
            "USER_GID": "1000"
        }
    },
    "workspaceFolder": "/work",
    "workspaceMount": "source=${localWorkspaceFolder}/work,target=/work,type=bind,consistency=cached",
    "mounts": [
        "source=${localWorkspaceFolder}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
    ],
    "remoteUser": "vscode",
    // .env ファイルから環境変数を読み込む
    "runArgs": ["--env-file", "${localWorkspaceFolder}/.devcontainer/.env"],
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "mhutchie.git-graph",
                "bierner.markdown-mermaid",
                "janisdd.vscode-edit-csv",
                "github.vscode-pull-request-github",
                "ms-python.python"

            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                }
            }
        }
    },
    "postCreateCommand": "bash /usr/local/bin/init-claude.sh"
}
