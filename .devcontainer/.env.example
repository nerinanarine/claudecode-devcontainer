# バックエンドの選択: 使用するバックエンドのセクションのコメントを外し、
# もう一方のセクションはコメントアウトしてください。
# このファイルをコピーして .env を作成してください: cp .env.example .env

# =============================================================================
# オプション A: Amazon Bedrock
# =============================================================================
CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=your-bearer-token-here

# =============================================================================
# オプション B: Azure AI Foundry
# =============================================================================
# CLAUDE_CODE_USE_FOUNDRY=1
# ANTHROPIC_FOUNDRY_RESOURCE=claudecode-nerina
# # または完全なURLで指定する場合:
# # ANTHROPIC_FOUNDRY_BASE_URL=https://claudecode-nerina.services.ai.azure.com
# ANTHROPIC_FOUNDRY_API_KEY=your-foundry-api-key-here
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-7
